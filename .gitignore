# =============================================================================
# 顶层 .gitignore
# =============================================================================

# OS 噪声
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.iml
*.ipr
*.iws

# 日志 / 临时
*.log
*.swp
*.bak

# =============================================================================
# 后端 (Spring Boot / Maven)
# =============================================================================
backend/target/
backend/.mvn/
backend/HELP.md

# 🔴 含真实 API Key 的本地配置, 绝不提交
backend/src/main/resources/application-local.yml
backend/src/main/resources/application-secrets.yml

# 后端运行时生成物
backend/generated/
backend/data/
backend/logs/

# =============================================================================
# 前端 (Node / Vite)
# =============================================================================
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/

# 前端环境变量
frontend/.env
frontend/.env.local
frontend/.env.*.local

# =============================================================================
# 第三方下载的项目源码 (这些是参考资料, 不属于本仓库)
# =============================================================================
XHS-Downloader-master/
md2wechat-skill-main/
Spider_XHS-master/

# =============================================================================
# 临时下载的输入文件
# =============================================================================
*.xlsx
!保险内容知识库.xlsx
